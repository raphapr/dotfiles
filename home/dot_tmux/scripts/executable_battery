#!/usr/bin/env bash

set -euo pipefail

readonly HEART='♥ '

battery_device="$(upower -e 2>/dev/null | grep '/battery_' | head -n 1 || true)"
if [[ -z "$battery_device" ]]; then
  printf '#[fg=colour254]AC'
  exit 0
fi

current_charge="$(upower -i "$battery_device" | awk '/percentage:/ { gsub(/%/, "", $2); print int($2); exit }')"
if [[ -z "$current_charge" ]]; then
  printf '#[fg=colour254]?'
  exit 0
fi

charged_slots=$(((current_charge + 32) / 33))
((charged_slots > 3)) && charged_slots=3
((charged_slots < 0)) && charged_slots=0

printf '#[fg=colour208]'
for ((i = 0; i < charged_slots; i++)); do
  printf '%s' "$HEART"
done

printf '#[fg=colour254]'
for ((i = charged_slots; i < 3; i++)); do
  printf '%s' "$HEART"
done
