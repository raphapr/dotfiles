#!/usr/bin/env python3
"""Manage and cycle tmux-sessionizer marks from tmux bindings."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import NamedTuple


MARK_PATTERN = re.compile(r"^\s*(\d+):\s+(.+?)\s+\((.*)\)\s*$")
DEFAULT_STATUS_ICON = "  "


class Mark(NamedTuple):
    index: int
    name: str
    path: str


def canonical_path(value: str) -> str:
    expanded = os.path.expandvars(os.path.expanduser(value))
    return str(Path(expanded).resolve(strict=False))


def parse_marks(raw: str) -> list[Mark]:
    marks: list[Mark] = []

    for line in raw.splitlines():
        match = MARK_PATTERN.match(line)
        if not match:
            continue

        index, name, path = match.groups()
        marks.append(Mark(int(index), name, canonical_path(path)))

    return sorted(marks, key=lambda mark: mark.index)


def current_mark_index(marks: list[Mark], session_name: str, session_path: str) -> int | None:
    current_path = canonical_path(session_path)

    for mark in marks:
        # tms creates tmux sessions with dots replaced by underscores.
        if session_name in {mark.name, mark.name.replace(".", "_")}:
            return mark.index

    for mark in marks:
        if mark.path == current_path:
            return mark.index

    return None


def choose_target(marks: list[Mark], current_index: int | None, direction: str) -> int:
    indexes = [mark.index for mark in marks]
    step = 1 if direction == "next" else -1

    if current_index not in indexes:
        return indexes[0] if direction == "next" else indexes[-1]

    return indexes[(indexes.index(current_index) + step) % len(indexes)]


def status_text(marks: list[Mark], session_name: str, session_path: str, icon: str) -> str:
    if current_mark_index(marks, session_name, session_path) is None:
        return ""
    return icon


def open_mark_command(index: int) -> list[str]:
    return ["tms", "marks", "open", str(index)]


def toggle_current_mark_command(
    marks: list[Mark], session_name: str, session_path: str
) -> list[str]:
    current_index = current_mark_index(marks, session_name, session_path)

    if current_index is not None:
        return ["tms", "marks", "delete", str(current_index)]

    return ["tms", "marks", "set", "--path", session_path]


def selected_mark_index(selection: str) -> int | None:
    match = MARK_PATTERN.match(selection)
    if match is None:
        return None

    index, _name, _path = match.groups()
    return int(index)


def selected_mark_path(selection: str) -> str | None:
    match = MARK_PATTERN.match(selection)
    if match is None:
        return None

    _index, _name, path = match.groups()
    return canonical_path(path)


def fzf_command() -> list[str]:
    return [
        "fzf",
        "--no-sort",
        "--layout",
        "default",
        "--height",
        "100%",
        "--prompt",
        "> ",
    ]


def run(
    command: list[str], check: bool = True, stdin: str | None = None
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        command,
        check=check,
        text=True,
        input=stdin,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def tmux(*args: str, check: bool = True) -> subprocess.CompletedProcess[str]:
    return run(["tmux", *args], check=check)


def tms(*args: str, check: bool = True) -> subprocess.CompletedProcess[str]:
    return run(["tms", *args], check=check)


def display(message: str) -> None:
    print(message, file=sys.stderr)
    tmux("display-message", message, check=False)


def read_marks() -> list[Mark]:
    return parse_marks(tms("marks", "list").stdout)


def current_session() -> tuple[str, str]:
    result = tmux("display-message", "-p", "#{session_name}\t#{session_path}")
    name, path = result.stdout.rstrip("\n").split("\t", 1)
    return name, path


def print_mark_list(marks: list[Mark], current_index: int | None) -> None:
    for mark in marks:
        marker = "*" if mark.index == current_index else " "
        print(f"{marker} {mark.index}: {mark.name} ({mark.path})")


def open_next_mark(marks: list[Mark], direction: str) -> int:
    if not marks:
        return 0

    session_name, session_path = current_session()
    current_index = current_mark_index(marks, session_name, session_path)

    if len(marks) == 1 and current_index == marks[0].index:
        return 0

    target = choose_target(marks, current_index, direction)
    run(open_mark_command(target))
    tmux("refresh-client", "-S", check=False)
    return 0


def mark_current_session(marks: list[Mark]) -> int:
    session_name, session_path = current_session()
    run(toggle_current_mark_command(marks, session_name, session_path))
    tmux("refresh-client", "-S", check=False)
    return 0


def print_preview(selection: str) -> int:
    path = selected_mark_path(selection)
    if path is None:
        return 0

    print(path)
    print()

    branch = run(["git", "-C", path, "branch", "--show-current"], check=False)
    if branch.returncode == 0 and branch.stdout.strip():
        print(f"branch: {branch.stdout.strip()}")
        print()

    status = run(["git", "-C", path, "status", "--short"], check=False)
    if status.returncode == 0:
        print("status:")
        print(status.stdout.rstrip() or "clean")
        return 0

    entries = sorted(Path(path).glob("*"))[:20]
    if entries:
        print("files:")
        for entry in entries:
            suffix = "/" if entry.is_dir() else ""
            print(f"{entry.name}{suffix}")

    return 0


def pick_mark() -> int:
    raw_marks = tms("marks", "list").stdout
    if raw_marks.strip() == "":
        return 0

    selection = run(fzf_command(), check=False, stdin=raw_marks)
    if selection.returncode != 0:
        return 0

    index = selected_mark_index(selection.stdout.strip())
    if index is None:
        return 0

    run(open_mark_command(index))
    tmux("refresh-client", "-S", check=False)
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Manage tms marks from tmux.")
    subcommands = parser.add_subparsers(dest="command")

    subcommands.add_parser("next", help="open the next mark")
    subcommands.add_parser("prev", help="open the previous mark")
    subcommands.add_parser("list", help="list marks and mark the current one")
    open_parser = subcommands.add_parser("open", help="open a mark by index")
    open_parser.add_argument("index", type=int, help="mark index")
    subcommands.add_parser("pick", help="pick and open a mark with fzf")
    preview = subcommands.add_parser("preview", help="show fzf preview for a mark")
    preview.add_argument("selection", nargs="?", default="", help="selected mark line")
    subcommands.add_parser("mark-current", help="toggle the current tmux session path as a mark")

    status = subcommands.add_parser("status", help="print a marker if the current session is marked")
    status.add_argument("session_name", nargs="?", help="tmux session name")
    status.add_argument("session_path", nargs="?", help="tmux session path")
    status.add_argument("--icon", default=DEFAULT_STATUS_ICON, help="status text to print")

    parser.set_defaults(command="next")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    marks = read_marks()

    if args.command in {"next", "prev"}:
        return open_next_mark(marks, args.command)

    if args.command == "list":
        session_name, session_path = current_session()
        print_mark_list(marks, current_mark_index(marks, session_name, session_path))
        return 0

    if args.command == "open":
        run(open_mark_command(args.index))
        tmux("refresh-client", "-S", check=False)
        return 0

    if args.command == "pick":
        return pick_mark()

    if args.command == "preview":
        return print_preview(args.selection)

    if args.command == "mark-current":
        return mark_current_session(marks)

    if args.command == "status":
        if args.session_name is None or args.session_path is None:
            args.session_name, args.session_path = current_session()
        print(status_text(marks, args.session_name, args.session_path, args.icon), end="")
        return 0

    return 1


if __name__ == "__main__":
    raise SystemExit(main())
