#!/bin/bash

set -euo pipefail

PKGLIST="$HOME/.pkglist"
PKGLIST_OFFICIAL="$PKGLIST/official/common"
PKGLIST_AUR="$PKGLIST/aur/packages"

mkdir -p "$(dirname "$PKGLIST_OFFICIAL")" "$(dirname "$PKGLIST_AUR")"

official_tmp="$(mktemp "${PKGLIST_OFFICIAL}.XXXXXX")"
aur_tmp="$(mktemp "${PKGLIST_AUR}.XXXXXX")"
trap 'rm -f "$official_tmp" "$aur_tmp"' EXIT

# Keep only explicitly installed packages. Write to temporary files so a
# failed pacman query never truncates the tracked manifests.
pacman -Qqen >"$official_tmp"
pacman -Qqem >"$aur_tmp"

mv "$official_tmp" "$PKGLIST_OFFICIAL"
mv "$aur_tmp" "$PKGLIST_AUR"
trap - EXIT

printf 'Successfully backed up package lists to %s\n' "$PKGLIST"
