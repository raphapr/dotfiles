#!/usr/bin/env bash
# Fuzzy find Pi orchestration PLAN.md files.
#
# Default behaviour:
#   1. Detect the current repo (ghq layout under $GHQ_ROOT, or git remote origin).
#   2. If that repo has plans, skip the repo picker and go straight to the
#      plan picker for that repo.
#   3. Otherwise, show a repo picker first, then a plan picker for the chosen
#      repo.
#
# Enter opens the selected PLAN.md in $EDITOR (default: nvim).
#
# Flags:
#   -a, --all   Force the repo picker even when the current repo has plans.
#               Only affects step 1; step 2 still drills into one repo.
#   -h, --help  Show this help.

set -euo pipefail

GHQ_ROOT="${GHQ_ROOT:-$HOME/repos}"
PLANS_ROOT="$HOME/.pi/orchestra/plans"
EDITOR_CMD="${EDITOR:-nvim}"

force_picker=0
for arg in "$@"; do
  case "$arg" in
  -a | --all) force_picker=1 ;;
  -h | --help)
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
  esac
done

detect_scope() {
  local cwd host owner repo url hor
  cwd="$(pwd -P)"

  if [[ "$cwd" == "$GHQ_ROOT"/* ]]; then
    IFS='/' read -r host owner repo _ <<<"${cwd#"$GHQ_ROOT"/}"
    if [[ -n "${host:-}" && -n "${owner:-}" && -n "${repo:-}" ]]; then
      printf '%s/%s/%s/%s\n' "$PLANS_ROOT" "$host" "$owner" "$repo"
      return
    fi
  fi

  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    url="$(git remote get-url origin 2>/dev/null || true)"
    if [[ -n "$url" ]]; then
      hor="${url%.git}"
      hor="${hor#git@}"
      hor="${hor/://}"
      hor="${hor#https://}"
      hor="${hor#http://}"
      hor="${hor#*@}"
      IFS='/' read -r host owner repo _ <<<"$hor"
      if [[ -n "${host:-}" && -n "${owner:-}" && -n "${repo:-}" ]]; then
        printf '%s/%s/%s/%s\n' "$PLANS_ROOT" "$host" "$owner" "$repo"
        return
      fi
    fi
  fi
}

pick_plan_in_repo() {
  local repo_path="$1"
  local plans
  # Sort newest-first so the HHMM-prefixed plan directories list in reverse-chronological order.
  plans="$(find "$repo_path" -type f -name PLAN.md 2>/dev/null |
    LC_ALL=C sort -r |
    awk -v base="$repo_path/" '
        BEGIN { blen = length(base) }
        substr($0, 1, blen) == base { print substr($0, blen + 1) "\t" $0 }
      ')"

  if [[ -z "$plans" ]]; then
    echo "No plans found under $repo_path" >&2
    exit 0
  fi

  printf '%s\n' "$plans" |
    fzf \
      --prompt='PLAN.md ▸ ' \
      --delimiter=$'\t' \
      --with-nth=1 \
      --preview 'bat --style=plain --color=always {2} 2>/dev/null || cat {2}' \
      --preview-window=right:70%:wrap \
      --bind "enter:become($EDITOR_CMD {2})"
}

# Fast path: current repo has plans -> go straight to the plan picker.
if [[ $force_picker -eq 0 ]]; then
  scope="$(detect_scope)"
  if [[ -n "$scope" && -d "$scope" ]] &&
    [[ -n "$(find "$scope" -type f -name PLAN.md -print -quit 2>/dev/null)" ]]; then
    pick_plan_in_repo "$scope"
    exit 0
  fi
fi

# Slow path: pick a repo dir, then a plan inside it.
repos="$(find "$PLANS_ROOT" -type f -name PLAN.md 2>/dev/null |
  sed -E 's|/[^/]+/PLAN\.md$||' |
  sort -u |
  sed -E 's|^.*/plans/(([^/]+\.[^/]+/)?(.*))|\3\t&|')"

if [[ -z "$repos" ]]; then
  echo "No plans found under $PLANS_ROOT" >&2
  exit 0
fi

repo_sel="$(printf '%s\n' "$repos" |
  fzf \
    --prompt='repo ▸ ' \
    --delimiter=$'\t' \
    --with-nth=1 \
    --preview 'ls -1 {2}' \
    --preview-window=right:50%:wrap)"

[[ -z "$repo_sel" ]] && exit 0
pick_plan_in_repo "${repo_sel#*$'\t'}"
