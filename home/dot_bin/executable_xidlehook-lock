#!/usr/bin/env bash

set -euo pipefail

: "${XDG_RUNTIME_DIR:?XDG_RUNTIME_DIR must be set}"

# Run xidlehook. Keep locking active for fullscreen applications; use an
# explicit presentation-mode tool instead of leaving the session unlocked.
xidlehook \
  --socket "$XDG_RUNTIME_DIR/xidlehook.sock" \
  `# Dim the screen after 5 minutes, undim if user becomes active` \
  --timer 300 \
  'brightnessctl set 125-; notify-send "Screen will be locked in 30s"' \
  'brightnessctl set 125+' \
  `# Undim & lock after 30 more seconds` \
  --timer 30 \
  'loginctl lock-session; brightnessctl set 125+' \
  '' \
  `# Finally, suspend an hour after it locks` \
  --timer 3600 \
  'systemctl suspend' \
  ''
