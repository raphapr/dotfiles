#!/bin/bash

# Centralized keyboard repeat rate configuration
# Usage: set-keyboard-repeat [delay] [rate]
# Default: delay=240ms, rate=30 repeats/second

DELAY=${1:-240}
RATE=${2:-30}

# Set keyboard repeat rate
xset r rate "$DELAY" "$RATE"

# Reapply xkb options to kanata's virtual keyboard device (caps:none gets lost on device reinit)
setxkbmap -option caps:none

# If Caps Lock is still on after kanata grabs the keyboard, force it off
if xset q | grep -q "Caps Lock:   on"; then
  xdotool key Caps_Lock
fi