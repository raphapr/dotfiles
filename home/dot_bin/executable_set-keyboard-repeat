#!/bin/bash

# Centralized keyboard repeat rate configuration
# Usage: set-keyboard-repeat [delay] [rate]
# Default: delay=240ms, rate=30 repeats/second

DELAY=${1:-240}
RATE=${2:-30}

# Set keyboard repeat rate
xset r rate "$DELAY" "$RATE"

# Clear stale XKB options, preserve pointer keys, and map Caps Lock to
# Control_L consistently, including after Kanata recreates its device.
setxkbmap -option '' -option keypad:pointerkeys -option ctrl:nocaps
