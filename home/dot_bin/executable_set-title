#!/usr/bin/env bash

set -euo pipefail

window_id="$(xdotool getactivewindow)"
current_title="$(xdotool getwindowname "$window_id")"

if ! title="$(printf '%s\n' "${*:-$current_title}" | rofi -dmenu -p "Window title")"; then
  exit 0
fi

[[ -n "$title" ]] || exit 0
xdotool set_window --name "$title" "$window_id"
