#!/bin/bash
# Re-runs whenever the mise config changes.
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

set -euo pipefail

if ! command -v mise >/dev/null 2>&1; then
  echo ">> mise is required but was not installed by the previous bootstrap step." >&2
  exit 1
fi

echo ">> Syncing mise tools..."
mise install --yes
echo ">> Skipping destructive prune; review with: mise prune --dry-run"
